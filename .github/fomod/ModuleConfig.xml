<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">
  <moduleName>Bars Graphics</moduleName>
  <moduleImage path="icon.png" />
  <installSteps order="Explicit">
    <installStep name="Install Bars Graphics">
      <optionalFileGroups order="Explicit">
        <group name="Schedule I MelonLoader files" type="SelectAll">
          <plugins order="Explicit">
            <plugin name="Bars Graphics">
              <description>Installs BarsGraphics.dll to Mods and bGUI.dll to UserLibs. Use F5 in game for the menu and F6 to toggle the optimizer.</description>
              <image path="icon.png" />
              <files>
                <folder source="Mods" destination="Mods" priority="0" />
                <folder source="UserLibs" destination="UserLibs" priority="0" />
                <folder source="LICENSES" destination="BarsGraphics-LICENSES" priority="0" />
              </files>
              <typeDescriptor>
                <type name="Required" />
              </typeDescriptor>
            </plugin>
          </plugins>
        </group>
      </optionalFileGroups>
    </installStep>
  </installSteps>
</config>
